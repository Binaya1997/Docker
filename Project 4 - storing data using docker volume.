---

# Step 4 — Create server.js

```bash
nano server.js
```

Add:

```javascript
const express = require('express');
const cors = require('cors');
const { Pool } = require('pg');

const app = express();

app.use(cors());
app.use(express.json());

const pool = new Pool({
    user: 'admin',
    host: 'host.docker.internal',
    database: 'kutu_db',
    password: 'admin123',
    port: 5432,
});

pool.query(`
CREATE TABLE IF NOT EXISTS users (
    id SERIAL PRIMARY KEY,
    name TEXT
)
`);

app.post('/add-user', async (req, res) => {

    const { name } = req.body;

    await pool.query(
        'INSERT INTO users(name) VALUES($1)',
        [name]
    );

    res.send('User added successfully');
});

app.get('/users', async (req, res) => {

    const result = await pool.query(
        'SELECT * FROM users'
    );

    res.json(result.rows);
});

app.listen(5000, () => {
    console.log('Backend running on port 5000');
});
```

---

# Step 5 — Create Backend Dockerfile

```bash
nano Dockerfile
```

Add:

```dockerfile
FROM node:18-alpine

WORKDIR /app

COPY package.json .

RUN npm install

COPY . .

EXPOSE 5000

CMD ["npm", "start"]
```

---

# Step 6 — Build Backend Image

```bash
docker build -t kutu-db-backend .
```

---

# Step 7 — Go Back to Project Root

```bash
cd ..
```

---

# Step 8 — Create Frontend Folder

```bash
mkdir frontend
